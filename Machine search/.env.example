# ============================================================
# Multi-Source File Search Application - Environment Config
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to version control!

# ============================================================
# GOOGLE DRIVE API SETTINGS
# ============================================================
# Get these from https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable the Google Drive API
# 3. Create OAuth 2.0 credentials (Desktop App)
# 4. Download credentials.json and place it in the project root

GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Scopes for Google Drive (do not change unless you know what you're doing)
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# ============================================================
# LOCAL SEARCH SETTINGS
# ============================================================
# Comma-separated list of root directories to search on your computer
# Examples:
#   Windows: C:\Users\YourName\Documents,C:\Users\YourName\Downloads,D:\Projects
#   Linux/Mac: /home/yourname/Documents,/home/yourname/Downloads

LOCAL_SEARCH_PATHS=C:\Users\thake\Documents,C:\Users\thake\Downloads,C:\Users\thake\Desktop

# Maximum depth of directory traversal for local search (0 = unlimited)
LOCAL_SEARCH_MAX_DEPTH=10

# Maximum file size to scan in MB (files larger than this will be skipped for content search)
LOCAL_SEARCH_MAX_FILE_SIZE_MB=50

# Comma-separated list of file extensions to EXCLUDE from local search
LOCAL_EXCLUDE_EXTENSIONS=.exe,.dll,.sys,.bin,.iso,.img,.vmdk,.tmp,.log

# ============================================================
# WHATSAPP SETTINGS
# ============================================================
# Path to WhatsApp Desktop backup/media folder
# On Windows, WhatsApp stores data here by default:
WHATSAPP_DESKTOP_PATH=C:\Users\thake\AppData\Local\Packages\5319275A.WhatsAppDesktop_cv1g1gvanyjgm\LocalState\shared\transfers

# Path to WhatsApp exported chat folders (if you've exported chats manually)
# In WhatsApp: Open chat > More options > Export chat > Save to folder
WHATSAPP_EXPORT_PATH=C:\Users\thake\Documents\WhatsApp Chats

# Path to Android WhatsApp backup (if you've connected your phone or have a backup)
# Usually found at: Phone\Internal Storage\WhatsApp\
WHATSAPP_ANDROID_BACKUP_PATH=

# WhatsApp Web session (leave blank if not using WhatsApp Web automation)
WHATSAPP_WEB_SESSION_PATH=

# ============================================================
# UPLOAD SETTINGS
# ============================================================
# Folder where uploaded files are temporarily stored
UPLOAD_FOLDER=uploads

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=100

# ============================================================
# SEARCH SETTINGS
# ============================================================
# Minimum similarity score (0.0 to 1.0) to include in results
# Higher value = stricter matching
IMAGE_SIMILARITY_THRESHOLD=0.85
TEXT_SIMILARITY_THRESHOLD=0.60
PDF_SIMILARITY_THRESHOLD=0.65

# Maximum number of results to return per source
MAX_RESULTS_PER_SOURCE=20

# ============================================================
# APP SETTINGS
# ============================================================
# Flask secret key - change this to a random string!
SECRET_KEY=change-this-to-a-random-secret-key-abc123

# Flask environment: development or production
FLASK_ENV=development

# Port to run the app on
PORT=5000

# Enable debug mode (True/False) - set to False in production
DEBUG=True

# ============================================================
# OPTIONAL: GOOGLE CLOUD VISION API (for better image search)
# ============================================================
# If you want more powerful image similarity, enable Vision API
# Get API key from https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=

# ============================================================
# OPTIONAL: OPENAI API (for semantic text understanding)
# ============================================================
OPENAI_API_KEY=
