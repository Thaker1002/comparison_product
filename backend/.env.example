# ─── Thaker's Quest — Backend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Tavily ───────────────────────────────────────────────────────────────────
# Get your API key from https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend (used for CORS allow-origin header)
FRONTEND_URL=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens (change this to a long random string!)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin dashboard password (used to access /admin route)
ADMIN_SECRET=your-admin-password-here

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used to send users their auto-generated password after registration.
# Example below uses Gmail App Password (create one at myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=PriceHunt <your-email@gmail.com>

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Used for Distance Matrix API (real road distance + duration for fare estimates)
# Enable "Distance Matrix API" at console.cloud.google.com/apis
GOOGLE_MAPS_API_KEY=AIzaSyAhlQd0NyVC-ex0G5ySR91US0GMcXwy2NQ
