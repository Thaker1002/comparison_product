// ─── Search Panel ─────────────────────────────────────────────────────────────

interface SearchPanelProps {
  query: string;
  onQueryChange: (q: string) => void;
  onSearch: () => void;
  filters: SearchFilters;
  onFiltersChange: (f: Partial<SearchFilters>) => void;
  uploadedImage: UploadedImage | null;
  onImageChange: (img: UploadedImage | null) => void;
  isLoading: boolean;
  resultCount?: number;
}

function SearchPanel({
  query,
  onQueryChange,
  onSearch,
  filters,
  onFiltersChange,
  uploadedImage,
  onImageChange,
  isLoading,
  resultCount,
}: SearchPanelProps) {
  const [showImageUpload, setShowImageUpload] = useState(false);

  // Image-name confirmation state
  // When a new image is uploaded and a name is auto-extracted, we show a
  // small inline banner so the user can review / edit it before searching.
  const [pendingImageName, setPendingImageName] = useState<string | null>(null);
  const [editingImageName, setEditingImageName] = useState("");
  const [isEditingName, setIsEditingName] = useState(false);
  const nameInputRef = useRef<HTMLInputElement>(null);

  // Focus the inline edit input when it becomes visible
  useEffect(() => {
    if (isEditingName && nameInputRef.current) {
      nameInputRef.current.focus();
      nameInputRef.current.select();
    }
  }, [isEditingName]);

  // Clear the confirmation banner when the image is removed
  useEffect(() => {
    if (!uploadedImage) {
      setPendingImageName(null);
      setEditingImageName("");
      setIsEditingName(false);
    }
  }, [uploadedImage]);

  const handleConfirmImageName = () => {
    const confirmed = editingImageName.trim();
    if (confirmed.length >= 2) {
      onQueryChange(confirmed);
    }
    setPendingImageName(null);
    setIsEditingName(false);
  };

  const handleDismissImageName = () => {
    setPendingImageName(null);
    setIsEditingName(false);
  };

  return (
    <div className="glass-card rounded-3xl border border-border/50 p-6 shadow-2xl shadow-black/20 space-y-5">
      {/* Image upload toggle */}
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-2">
          <div className="w-8 h-8 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center">
            <ShoppingBag className="w-4 h-4 text-primary" />
          </div>
          <div>
            <h2 className="text-sm font-semibold text-foreground">
              Product Search
            </h2>
            <p className="text-[11px] text-muted-foreground">
              Search by name or upload an image
            </p>
          </div>
        </div>
        <button
          onClick={() => setShowImageUpload((v) => !v)}
          className={cn(
            "flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold border",
            "transition-all duration-200",
            showImageUpload || uploadedImage
              ? "bg-primary/10 border-primary/30 text-primary"
              : "border-border/50 text-muted-foreground hover:text-foreground hover:border-border bg-secondary/30",
          )}
        >
          <Camera className="w-3.5 h-3.5" />
          {uploadedImage ? "Image ready ✓" : "Upload Image"}
        </button>
      </div>

      {/* Image upload area */}
      {(showImageUpload || uploadedImage) && (
        <div className="animate-fade-in">
          <ImageUpload
            currentImage={uploadedImage}
            onImageChange={(img) => {
              onImageChange(img);
              if (!img) {
                setShowImageUpload(false);
                setPendingImageName(null);
              }
            }}
            onProductNameExtracted={(name) => {
              // Always surface the auto-extracted name as a confirmation prompt
              // so the user can review and correct it before searching.
              setPendingImageName(name);
              setEditingImageName(name);
              setIsEditingName(false);
              // Pre-fill the query box silently only when it's empty
              if (!query || query.trim().length < 3) {
                onQueryChange(name);
              }
            }}
            disabled={isLoading}
            className="max-w-full"
          />

          {/* ── Image-name confirmation banner ─────────────────────────── */}
          {uploadedImage && pendingImageName && (
            <div className="mt-3 rounded-xl border border-amber-500/30 bg-amber-500/5 px-4 py-3 animate-fade-in">
              <div className="flex items-start gap-2">
                <span className="text-base leading-none mt-0.5">🖼️</span>
                <div className="flex-1 min-w-0">
                  <p className="text-[11px] font-semibold text-amber-400 mb-1">
                    Product name auto-detected from image filename
                  </p>

                  {isEditingName ? (
                    /* Inline edit mode */
                    <div className="flex items-center gap-2 mt-1.5">
                      <input
                        ref={nameInputRef}
                        type="text"
                        value={editingImageName}
                        onChange={(e) => setEditingImageName(e.target.value)}
                        onKeyDown={(e) => {
                          if (e.key === "Enter") handleConfirmImageName();
                          if (e.key === "Escape") {
                            setIsEditingName(false);
                          }
                        }}
                        className={cn(
                          "flex-1 min-w-0 px-2.5 py-1 rounded-lg text-xs",
                          "bg-background/80 border border-amber-500/40 text-foreground",
                          "focus:outline-none focus:ring-1 focus:ring-amber-500/50",
                        )}
                        placeholder="Type the product name…"
                      />
                      <button
                        onClick={handleConfirmImageName}
                        className="shrink-0 px-2.5 py-1 rounded-lg bg-amber-500/20 border border-amber-500/40 text-amber-300 text-[11px] font-semibold hover:bg-amber-500/30 transition-colors"
                      >
                        Use
                      </button>
                      <button
                        onClick={() => setIsEditingName(false)}
                        className="shrink-0 text-[11px] text-muted-foreground hover:text-foreground transition-colors"
                      >
                        Cancel
                      </button>
                    </div>
                  ) : (
                    /* Read-only preview mode */
                    <div className="flex items-center gap-2 flex-wrap mt-1">
                      <span className="flex-1 min-w-0 px-2.5 py-1 rounded-lg bg-background/60 border border-border/50 text-xs text-foreground font-medium truncate">
                        {pendingImageName}
                      </span>
                      <button
                        onClick={() => {
                          setIsEditingName(true);
                        }}
                        className="shrink-0 flex items-center gap-1 px-2 py-1 rounded-lg border border-border/50 text-[11px] text-muted-foreground hover:text-foreground hover:border-border transition-colors"
                      >
                        ✏️ Edit
                      </button>
                      <button
                        onClick={handleDismissImageName}
                        className="shrink-0 text-[11px] text-muted-foreground/60 hover:text-muted-foreground transition-colors"
                        title="Dismiss"
                      >
                        ✕
                      </button>
                    </div>
                  )}

                  <p className="text-[10px] text-muted-foreground/70 mt-1.5">
                    Edit the name above if it's incorrect, then search.
                  </p>
                </div>
              </div>
            </div>
          )}

          {uploadedImage && !pendingImageName && (
            <p className="mt-2 text-center text-[11px] text-muted-foreground">
              💡 The image will be sent alongside your search query for better
              results
            </p>
          )}
        </div>
      )}

      {/* Divider when image upload is shown */}
      {(showImageUpload || uploadedImage) && (
        <div className="flex items-center gap-3">
          <div className="flex-1 h-px bg-border/40" />
          <span className="text-[11px] text-muted-foreground font-medium px-2">
            or search by name
          </span>
          <div className="flex-1 h-px bg-border/40" />
        </div>
      )}

      {/* Search bar */}
      <SearchBar
        query={query}
        onQueryChange={onQueryChange}
        onSearch={onSearch}
        filters={filters}
        onFiltersChange={onFiltersChange}
        isLoading={isLoading}
        resultCount={resultCount}
      />
    </div>
  );
}

// ─── Inner App (uses hooks) ───────────────────────────────────────────────────

function AppInner() {
  const [query, setQuery] = useState("");
  const [uploadedImage, setUploadedImage] = useState<UploadedImage | null>(
    null,
  );
  const [filters, setFilters] = useState<SearchFilters>(DF);
  const [searchResults, setSearchResults] = useState<SearchResponse | null>(
    null,
  );
  const [hasSearched, setHasSearched] = useState(false);

  const updateFilters = useCallback((partial: Partial<SearchFilters>) => {
    setFilters((prev) => ({ ...prev, ...partial }));
  }, []);

  // TanStack useMutation for search
  const searchMutation = useMutation({
    mutationFn: searchProducts,
    onSuccess: (data) => {
      setSearchResults(data);
      setHasSearched(true);
      // Scroll to results
      setTimeout(() => {
        document.getElementById("results-section")?.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }, 200);
    },
    onError: (err) => {
      console.error("Search failed:", err);
    },
  });

  const handleSearch = useCallback(() => {
    const trimmed = query.trim();
    if (trimmed.length < 2) return;

    searchMutation.mutate({
      query: trimmed,
      marketplaces: filters.marketplaces,
      searchMode: filters.searchMode,
      image: uploadedImage?.preview,
    });
  }, [query, filters, uploadedImage, searchMutation]);

  const handleQuickSearch = useCallback(
    (q: string) => {
      setQuery(q);
      searchMutation.mutate({
        query: q,
        marketplaces: filters.marketplaces,
        searchMode: filters.searchMode,
      });
    },
    [filters, searchMutation],
  );

  const isLoading = searchMutation.isPending;
  const isError = searchMutation.isError;

  return (
    <div className="min-h-screen flex flex-col">
      {/* Header */}
      <Header />

      {/* Main content */}
      <main className="flex-1">
        {/* Hero section (hide after first search) */}
        {!hasSearched && <Hero onQuickSearch={handleQuickSearch} />}

        {/* Search panel */}
        <section
          className={cn(
            "mx-auto max-w-4xl px-4",
            hasSearched ? "pt-6" : "pt-0",
          )}
        >
          <SearchPanel
            query={query}
            onQueryChange={setQuery}
            onSearch={handleSearch}
            filters={filters}
            onFiltersChange={updateFilters}
            uploadedImage={uploadedImage}
            onImageChange={setUploadedImage}
            isLoading={isLoading}
            resultCount={searchResults?.totalResults}
          />
        </section>

        {/* Error state */}
        {isError && (
          <section className="mx-auto max-w-4xl px-4 mt-6 animate-fade-in">
            <div className="glass-card rounded-2xl border border-red-500/20 bg-red-500/5 p-5 flex items-start gap-4">
              <div className="w-10 h-10 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center shrink-0">
                <span className="text-xl">⚠️</span>
              </div>
              <div className="flex-1 min-w-0">
                <h3 className="text-sm font-semibold text-red-400 mb-1">
                  Search Failed
                </h3>
                <p className="text-xs text-muted-foreground leading-relaxed">
                  {searchMutation.error instanceof Error
                    ? searchMutation.error.message
                    : "Could not connect to the search API. Make sure the backend server is running on port 3001."}
                </p>
                <div className="mt-3 flex items-center gap-2 flex-wrap">
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={handleSearch}
                    className="border-red-500/30 text-red-400 hover:bg-red-500/10 text-xs"
                  >
                    Try Again
                  </Button>
                  <p className="text-[11px] text-muted-foreground">
                    Backend URL:{" "}
                    <code className="text-foreground font-mono">
                      http://localhost:3001
                    </code>
                  </p>
                </div>
              </div>
            </div>
          </section>
        )}

        {/* Results */}
        <section
          id="results-section"
          className={cn(
            "mx-auto max-w-7xl px-4 pb-16",
            hasSearched || isLoading ? "mt-8" : "mt-0",
          )}
        >
          {(isLoading || hasSearched) && (
            <>
              {/* Results header */}
              {hasSearched && !isLoading && searchResults && (
                <div className="flex items-center justify-between mb-6 animate-fade-in">
                  <div className="flex items-center gap-3">
                    <div className="flex items-center gap-2">
                      <h2 className="text-lg font-bold text-foreground">
                        Results for{" "}
                        <span className="gradient-text">
                          "{searchResults.query}"
                        </span>
                      </h2>
                    </div>
                    <Badge variant="info" className="text-[11px]">
                      {searchResults.totalResults} products
                    </Badge>
                    <Badge variant="secondary" className="text-[11px]">
                      {searchResults.marketplacesSearched} marketplaces
                    </Badge>
                    {searchResults._meta &&
                      searchResults._meta.fallbackUrlCount > 0 && (
                        <Badge
                          variant="warning"
                          className="text-[11px] gap-1 cursor-help"
                          title={`${searchResults._meta.fallbackUrlCount} product link(s) (${searchResults._meta.fallbackUrlPct}%) could not be verified and were replaced with marketplace search pages. These are shown with a "Search on Site" button.`}
                        >
                          ⚠️ {searchResults._meta.fallbackUrlCount} search
                          fallback
                          {searchResults._meta.fallbackUrlCount !== 1
                            ? "s"
                            : ""}
                        </Badge>
                      )}
                  </div>

                  <div className="flex items-center gap-2">
                    <span className="text-xs text-muted-foreground hidden sm:block">
                      {new Date(searchResults.timestamp).toLocaleTimeString(
                        "th-TH",
                      )}
                    </span>
                    <Button
                      variant="outline"
                      size="sm"
                      onClick={handleSearch}
                      disabled={isLoading}
                      className="gap-1.5 text-xs"
                    >
                      <Search className="w-3.5 h-3.5" />
                      Refresh
                    </Button>
                  </div>
                </div>
              )}

              <ResultsGrid
                products={searchResults?.products ?? []}
                summaries={searchResults?.summary ?? []}
                query={searchResults?.query ?? query}
                isLoading={isLoading}
                filters={filters}
                timestamp={searchResults?.timestamp}
              />
            </>
          )}

          {/* Initial empty state with CTA */}
          {!hasSearched && !isLoading && (
            <div className="mt-8 animate-fade-in delay-700">
              {/* How it works section */}
              <div className="text-center mb-8">
                <h2 className="text-xl font-bold text-foreground mb-2">
                  How It Works
                </h2>
                <p className="text-sm text-muted-foreground">
                  Three simple steps to find the best deal
                </p>
              </div>

              <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
                {[
                  {
                    step: "01",
                    icon: Camera,
                    title: "Upload or Type",
                    desc: "Upload a product photo or type the product name you want to compare",
                    color:
                      "from-indigo-500/15 to-indigo-600/5 border-indigo-500/20",
                    iconColor: "text-indigo-400",
                    badge: "Start here",
                  },
                  {
                    step: "02",
                    icon: Globe,
                    title: "AI Scrapes Markets",
                    desc: "Firecrawl AI visits Shopee, Lazada, JD Central, Big C and more simultaneously",
                    color:
                      "from-purple-500/15 to-purple-600/5 border-purple-500/20",
                    iconColor: "text-purple-400",
                    badge: "Automated",
                  },
                  {
                    step: "03",
                    icon: TrendingDown,
                    title: "Compare & Save",
                    desc: "See prices, ratings, capacity info and find the best deal instantly",
                    color:
                      "from-emerald-500/15 to-emerald-600/5 border-emerald-500/20",
                    iconColor: "text-emerald-400",
                    badge: "Save money",
                  },
                ].map(
                  ({
                    step,
                    icon: Icon,
                    title,
                    desc,
                    color,
                    iconColor,
                    badge,
                  }) => (
                    <div
                      key={step}
                      className={cn(
                        "relative rounded-2xl border p-5 bg-gradient-to-br text-center",
                        "transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-black/20",
                        color,
                      )}
                    >
                      {/* Step number */}
                      <div className="absolute -top-3 left-1/2 -translate-x-1/2">
                        <div className="px-3 py-0.5 rounded-full bg-background border border-border text-[10px] font-bold text-muted-foreground">
                          Step {step}
                        </div>
                      </div>

                      <div className="flex flex-col items-center gap-3 pt-2">
                        <div
                          className={cn(
                            "w-12 h-12 rounded-2xl bg-background/50 border border-white/10 flex items-center justify-center",
                            iconColor,
                          )}
                        >
                          <Icon className="w-6 h-6" />
                        </div>
                        <div>
                          <h3 className="text-sm font-bold text-foreground mb-1">
                            {title}
                          </h3>
                          <p className="text-[11px] text-muted-foreground leading-relaxed">
                            {desc}
                          </p>
                        </div>
                        <Badge variant="secondary" className="text-[10px]">
                          {badge}
                        </Badge>
                      </div>
                    </div>
                  ),
                )}
              </div>

              {/* CTA button */}
              <div className="flex justify-center mt-8">
                <button
                  onClick={() => {
                    document
                      .querySelector('input[type="text"]')
                      ?.scrollIntoView({ behavior: "smooth", block: "center" });
                    (
                      document.querySelector(
                        'input[type="text"]',
                      ) as HTMLInputElement
                    )?.focus();
                  }}
                  className="flex items-center gap-2 btn-gradient px-8 py-3 text-sm"
                >
                  <Sparkles className="w-4 h-4" />
                  Start Comparing Prices
                  <ArrowRight className="w-4 h-4" />
                </button>
              </div>
            </div>
          )}
        </section>
      </main>

      {/* Footer */}
      <footer className="border-t border-border/40 py-6 px-4 mt-auto">
        <div className="mx-auto max-w-7xl flex flex-col sm:flex-row items-center justify-between gap-3">
          <div className="flex items-center gap-2 text-xs text-muted-foreground">
            <ShoppingBag className="w-4 h-4 text-primary" />
            <span className="font-semibold gradient-text">Thaker's Quest</span>
            <span>·</span>
            <span>Powered by Firecrawl AI</span>
          </div>
          <div className="flex items-center gap-3 flex-wrap justify-center">
            {[
              "Shopee",
              "Lazada",
              "JD Central",
              "Big C",
              "Central",
              "Makro",
            ].map((m) => (
              <span key={m} className="text-[11px] text-muted-foreground/60">
                {m}
              </span>
            ))}
          </div>
          <p className="text-[11px] text-muted-foreground/50">
            © {new Date().getFullYear()} Thailand Markets
          </p>
        </div>
      </footer>
    </div>
  );
}

// ─── Root App (with providers) ────────────────────────────────────────────────

export default function App() {
  return (
    <QueryClientProvider client={queryClient}>
      <AppInner />
      {(import.meta as { env?: { DEV?: boolean } }).env?.DEV && (
        <ReactQueryDevtools initialIsOpen={false} />
      )}
    </QueryClientProvider>
  );
}
